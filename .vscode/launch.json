{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Chrome (with remote debugging)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5500/Beranda.html",
            "runtimeExecutable": "chrome",
            "preLaunchTask": "Start Python Server",
            "runtimeArgs": [
                "--remote-debugging-port=9222",
                "--user-data-dir=${workspaceFolder}\\.vscode\\chrome-user-data",
                "--disable-extensions"
            ],
            "webRoot": "${workspaceFolder}/frontend"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome (open Beranda.html)",
            "file": "${workspaceFolder}/frontend/Beranda.html",
            "webRoot": "${workspaceFolder}/frontend"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome (http://localhost:5500)",
            "url": "http://localhost:5500/Beranda.html",
            "webRoot": "${workspaceFolder}/frontend"
        }
        ,
        {
            "name": "Attach to Chrome (9222)",
            "type": "chrome",
            "request": "attach",
            "port": 9222,
            "webRoot": "${workspaceFolder}/frontend"
        }
    ]
}
